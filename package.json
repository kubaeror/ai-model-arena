{
  "name": "ai-model-arena",
  "version": "0.1.0",
  "description": "Automated, multi-model agentic coding arena with k8s-managed sandboxed sessions.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ai-arena": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsx --test tests/**/*.test.ts",
    "test:coverage": "c8 --lines 70 --functions 70 --branches 65 --statements 70 tsx --test $(cat .c8-test-list.txt)",
    "test:ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run test:db",
    "audit": "npm audit --audit-level=high --production",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "test:db": "tsx --test tests/db/**/*.test.ts tests/catalog/**/*.test.ts tests/lineage/**/*.test.ts tests/metrics/writeback.test.ts tests/providers/custom.test.ts tests/runner/checkpoint*.test.ts tests/session/**/*.test.ts tests/worker/**/*.test.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dashboard:dev": "concurrently -k -n api,web -c green,cyan \"tsx src/dashboard-server/server.ts\" \"npm --prefix src/dashboard-client run dev\"",
    "dashboard:build": "tsc && npm --prefix src/dashboard-client run build",
    "dashboard:start": "node dist/dashboard-server/server.js"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "argon2": "^0.45.0",
    "better-sqlite3": "^13.0.1",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.6.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "c8": "^12.0.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "tsx": "^4.19.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "allowScripts": {
    "argon2@0.45.0": true
  }
}
