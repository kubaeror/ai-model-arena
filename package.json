{
  "name": "ai-model-arena",
  "version": "0.1.0",
  "description": "Automated, multi-model agentic coding arena with PM2-managed sandboxed sessions.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ai-arena": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsx --test tests/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "test:db": "tsx --test tests/db/**/*.test.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dashboard:dev": "concurrently -k -n api,web -c green,cyan \"tsx src/dashboard-server/server.ts\" \"npm --prefix src/dashboard-client run dev\"",
    "dashboard:build": "tsc && npm --prefix src/dashboard-client run build",
    "dashboard:start": "node dist/dashboard-server/server.js"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pm2": "^7.0.3",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
