# ──────────────────────────────────────────────────────────────
# ai-model-arena environment configuration
# Copy this file to `.env` and fill in the keys you use.
# Keys are referenced by name from configs/models.yaml (apiKeyEnv).
# ──────────────────────────────────────────────────────────────

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini (optional; adapter left as an exercise)
GOOGLE_API_KEY=your-google-key

# Local OpenAI-compatible endpoint (Ollama / LM Studio)
# Ollama serves an OpenAI-compatible API at /v1 once `ollama serve` is running.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Dashboard web UI authentication
# Generate JWT secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
DASHBOARD_JWT_SECRET=
DASHBOARD_JWT_EXPIRES_IN=12h

# Structured log level: debug | info | warn | error
LOG_LEVEL=info

# Output root (default: <project>/outputs). Mount point for runner PVC in k8s.
# OUTPUT_ROOT=/var/arena/outputs
# SQLite DB path (default: <OUTPUT_ROOT>/arena.db). Postgres replaces this in Phase 1.
# ARENA_DB_PATH=

# ── Trace recording ─────────────────────────────────────────────────────────
# Enable local trace recording (default true). Set false to disable with zero overhead.
# Spans are stored as trace-meta.json and surfaced in the in-app Observability page.
OTEL_ENABLED=true
# Capture full prompts/completions into span attributes (default false — may
# contain sensitive data and increase payload size).
OTEL_CAPTURE_CONTENT=false
# OTLP exporter endpoint (set to enable remote tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4318
# Sampling ratio (0.0-1.0). Default 1.0 = trace everything. Set lower in production.
# OTEL_SAMPLING_RATIO=0.1

# ── API keys (programmatic access) ─────────────────────────────────────────
ARENA_API_KEY_CI=
ARENA_API_KEY_READONLY=

# ── Catalog (models.dev) sync ────────────────────────────────────────────────
# MODELS_DEV_API_URL=https://models.dev/api.json
# CATALOG_REFRESH_INTERVAL_DAYS=30

# Database driver: sqlite (default, dev) or postgres (k8s target)
# DB_DRIVER=postgres
# Postgres connection string (when DB_DRIVER=postgres)
# DATABASE_URL=postgres://arena:arena@localhost:5432/arena

# ── Redis queue configuration (when QUEUE_DRIVER=redis) ─────────────────────
# QUEUE_DRIVER=redis
# REDIS_URL=redis://:password@redis-host:6379
# REDIS_STREAM_PREFIX=arena:tasks
# REDIS_CONSUMER_GROUP=arena-runners
# MAX_TASK_ATTEMPTS=5
# REDIS_BLOCK_MS=5000
# REDIS_RECLAIM_IDLE_MS=60000
# REDIS_RECLAIM_INTERVAL_MS=30000
# ARENA_PROVIDER_FILTER=openai

# ── Amazon Bedrock ──────────────────────────────────────────────────────────
# AWS_BEDROCK_REGION=us-east-1
# AWS_BEDROCK_GATEWAY_URL=
# AWS_REGION=
# Note: In k8s, prefer EKS Pod Identity or IRSA over static credentials.
# The AWS SDK credential chain resolves IAM roles automatically.
