# ──────────────────────────────────────────────────────────────
# ai-model-arena environment configuration
# Copy this file to `.env` and fill in the keys you use.
# Keys are referenced by name from configs/models.yaml (apiKeyEnv).
# ──────────────────────────────────────────────────────────────

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini (optional; adapter left as an exercise)
GOOGLE_API_KEY=your-google-key

# Local OpenAI-compatible endpoint (Ollama / LM Studio)
# Ollama serves an OpenAI-compatible API at /v1 once `ollama serve` is running.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Dashboard web UI authentication
# Generate JWT secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
DASHBOARD_JWT_SECRET=
DASHBOARD_JWT_EXPIRES_IN=12h

# Structured log level: debug | info | warn | error
LOG_LEVEL=info

# ── Trace recording ─────────────────────────────────────────────────────────
# Enable local trace recording (default true). Set false to disable with zero overhead.
# Spans are stored as trace-meta.json and surfaced in the in-app Observability page.
OTEL_ENABLED=true
# Capture full prompts/completions into span attributes (default false — may
# contain sensitive data and increase payload size).
OTEL_CAPTURE_CONTENT=false

# ── API keys (programmatic access) ─────────────────────────────────────────
ARENA_API_KEY_CI=
ARENA_API_KEY_READONLY=

# ── Catalog (models.dev) sync ────────────────────────────────────────────────
# MODELS_DEV_API_URL=https://models.dev/api.json
# CATALOG_REFRESH_INTERVAL_DAYS=30
